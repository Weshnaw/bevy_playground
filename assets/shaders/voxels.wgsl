@group(0) @binding(0)
var voxels: texture_storage_3d<r32float, read>;

@group(0) @binding(1)
var<storage, read_write> index_head: atomic<u32>; // Can I avoid having this be a binding?

@group(0) @binding(2)
var<storage, read_write> vertex_head: atomic<u32>; // Can I avoid having this be a binding? 

@group(0) @binding(3)
var<storage, read_write> vertices: array<vec3<f32>>;

@group(0) @binding(4)
var<storage, read_write> indices: array<u32>;

@group(0) @binding(5)
var<storage, read_write> normals: array<vec3<f32>>;

@group(0) @binding(6)
var<storage, read_write> uvs: array<vec2<f32>>;

fn clamp(pos: vec3<u32>, max: vec3<u32>) -> f32 {
    if pos.x >= 0    && pos.y >= 0    && pos.z >= 0 &&
       pos.x < max.x && pos.y < max.y && pos.z < pos.z {
        let voxel = textureLoad(voxels, pos);
        return voxel.x;
    }

    return 0.;
}

fn interp_vertex(p1: vec3<f32>, p2: vec3<f32>, v1: f32, v2: f32) -> vec3<f32> {
    let mu = (0.5 - v1) / (v2 - v1);
    return p1 + mu * (p2 - p1);
}

@compute @workgroup_size(8, 8, 8)
fn main(@builtin(global_invocation_id) invocation_id: vec3<u32>) {
    let positions = array(
        vec3<f32>(invocation_id + OFFSET_LOOKUP[0u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[1u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[2u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[3u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[4u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[5u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[6u]),
        vec3<f32>(invocation_id + OFFSET_LOOKUP[7u]),
    );
    let dim = textureDimensions(voxels);
    let densities = array(
        clamp(invocation_id + OFFSET_LOOKUP[0u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[1u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[2u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[3u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[4u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[5u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[6u], dim),
        clamp(invocation_id + OFFSET_LOOKUP[7u], dim),
    );
    
    var cube_idx: u32 = 0u;
    cube_idx = cube_idx | u32(densities[0u] < 0.5) * (1u << 0u);
    cube_idx = cube_idx | u32(densities[1u] < 0.5) * (1u << 1u);
    cube_idx = cube_idx | u32(densities[2u] < 0.5) * (1u << 2u);
    cube_idx = cube_idx | u32(densities[3u] < 0.5) * (1u << 3u);
    cube_idx = cube_idx | u32(densities[4u] < 0.5) * (1u << 4u);
    cube_idx = cube_idx | u32(densities[5u] < 0.5) * (1u << 5u);
    cube_idx = cube_idx | u32(densities[6u] < 0.5) * (1u << 6u);
    cube_idx = cube_idx | u32(densities[7u] < 0.5) * (1u << 7u);

    if (cube_idx == 0x00u || cube_idx == 0xffu) {
        return;
    }

    var edges = EDGE_LOOKUP; // There has to be a better way then this, this could just be due to cargo-wgsl having older naga version

    var vertices = array(
        f32((edges[cube_idx] & (1u <<  0u)) != 0u) * interp_vertex(positions[0u], positions[1u], densities[0u], densities[1u]),
        f32((edges[cube_idx] & (1u <<  1u)) != 0u) * interp_vertex(positions[1u], positions[2u], densities[1u], densities[2u]),
        f32((edges[cube_idx] & (1u <<  2u)) != 0u) * interp_vertex(positions[2u], positions[3u], densities[2u], densities[3u]),
        f32((edges[cube_idx] & (1u <<  3u)) != 0u) * interp_vertex(positions[3u], positions[0u], densities[3u], densities[0u]),
        f32((edges[cube_idx] & (1u <<  4u)) != 0u) * interp_vertex(positions[4u], positions[5u], densities[4u], densities[5u]),
        f32((edges[cube_idx] & (1u <<  5u)) != 0u) * interp_vertex(positions[5u], positions[6u], densities[5u], densities[6u]),
        f32((edges[cube_idx] & (1u <<  6u)) != 0u) * interp_vertex(positions[6u], positions[7u], densities[6u], densities[7u]),
        f32((edges[cube_idx] & (1u <<  7u)) != 0u) * interp_vertex(positions[7u], positions[4u], densities[7u], densities[4u]),
        f32((edges[cube_idx] & (1u <<  8u)) != 0u) * interp_vertex(positions[0u], positions[4u], densities[0u], densities[4u]),
        f32((edges[cube_idx] & (1u <<  9u)) != 0u) * interp_vertex(positions[1u], positions[5u], densities[1u], densities[5u]),
        f32((edges[cube_idx] & (1u << 10u)) != 0u) * interp_vertex(positions[2u], positions[6u], densities[2u], densities[6u]),
        f32((edges[cube_idx] & (1u << 11u)) != 0u) * interp_vertex(positions[3u], positions[7u], densities[3u], densities[7u]),
    );

    var tri_idx: u32 = 0u;
    loop {
        // Technically vertex_head and index_head are always equal; but I may want to
        // cull duplicated verts at some point
        var start_vert_idx = atomicAdd(&vertex_head, 3u);
        var start_indices_idx = atomicAdd(&index_head, 3u);

        var tri = TRIANGLE_LOOKUP; // There has to be a better way then this, this could just be due to cargo-wgsl having older naga version
        let v0 = vertices[ tri[cube_idx][tri_idx + 0u] ];
        let v1 = vertices[ tri[cube_idx][tri_idx + 1u] ];
        let v2 = vertices[ tri[cube_idx][tri_idx + 2u] ];

        vertices[start_vert_idx + 0u] = v0;
        vertices[start_vert_idx + 1u] = v1;
        vertices[start_vert_idx + 2u] = v2;

        indices[start_indices_idx + 0u] = start_vert_idx + 0u;
        indices[start_indices_idx + 1u] = start_vert_idx + 1u;
        indices[start_indices_idx + 2u] = start_vert_idx + 2u;

        let normal = cross(v0 - v1, v0 - v2);
        normals[start_vert_idx + 0u] = normal;
        normals[start_vert_idx + 1u] = normal;
        normals[start_vert_idx + 2u] = normal;

        uvs[start_vert_idx + 0u] = vec2<f32>(0.0, 0.0);
        uvs[start_vert_idx + 1u] = vec2<f32>(1.0, 0.0);
        uvs[start_vert_idx + 2u] = vec2<f32>(0.0, 1.0);

        tri_idx = tri_idx + 3u;
        if (tri[cube_idx][tri_idx] == -1) {
            break;
        }
    }
    
}


